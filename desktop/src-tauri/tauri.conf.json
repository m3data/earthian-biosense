{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EarthianBioSense",
  "version": "0.1.0",
  "identifier": "earth.earthianlabs.biosense",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "EarthianBioSense",
        "width": 920,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "minimumSystemVersion": "12.0"
    }
  }
}
